#!/usr/bin/env bash
set -uo pipefail

if [[ $EUID -ne 0 ]]; then
    echo "Re-running with sudo..."
    exec sudo "$0" "$@"
fi

overall=0

while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    dev=$(awk '{print $1}' <<< "$line")
    type=$(awk '{for(i=1;i<=NF;i++) if($i=="-d"){print $(i+1); exit}}' <<< "$line")
    type="${type:-auto}"

    args=(-a "$dev")
    [[ "$type" != "auto" ]] && args+=(-d "$type")

    out=$(smartctl "${args[@]}" 2>&1)
    rc=$?

    fail=()

    # Any non-zero exit from smartctl is suspicious
    [[ $rc -ne 0 ]] && fail+=("smartctl exited with code $rc")

    # SATA/SAS health
    grep -qi "SMART overall-health.*FAILED" <<< "$out" && fail+=("SMART health FAILED")

    # NVMe critical warning (any non-zero value)
    if grep -qi "Critical Warning" <<< "$out"; then
        grep -qi "Critical Warning:[[:space:]]*0x0\+$" <<< "$out" || fail+=("NVMe critical warning")
    fi

    # SATA bad sector attributes
    for attr in "Reallocated_Sector_Ct" "Current_Pending_Sector" "Offline_Uncorrectable"; do
        val=$(awk -v a="$attr" '$0~a{print $NF; exit}' <<< "$out")
        [[ "${val:-0}" =~ ^[1-9][0-9]*$ ]] && fail+=("$attr: $val")
    done

    # Flag if no recognisable SMART data at all (likely permission or device issue)
    if ! grep -qi "SMART overall-health\|NVM Express\|Reallocated_Sector" <<< "$out"; then
        fail+=("No recognisable SMART data in output")
    fi

    if [[ ${#fail[@]} -eq 0 ]]; then
        echo "OK      $dev"
    else
        echo "════════════════════════════════════════"
        echo "FAIL    $dev"
        printf '        - %s\n' "${fail[@]}"
        echo "════════════════════════════════════════"
        echo "$out"
        echo
        overall=1
    fi

done < <(smartctl --scan-open)

echo
[[ $overall -eq 0 ]] && echo "All disks OK" || echo "Problems found"
exit $overall
