#!/usr/bin/env bash
set -euo pipefail

DATE="$(date +%F)"

BKP_01="/run/media/fede/bkp_01"

ARCHIVE="/run/media/fede/archive/"

BATOCERA_IP="$(batocera_ip 2>/dev/null | head -n1 | tr -d '\n\r')"
[[ -n "$BATOCERA_IP" ]] || {
  echo "ERROR: batocera_ip returned empty value"
  exit 1
}
BATOCERA_REMOTE="root@$BATOCERA_IP"

DRY_RUN="${DRY_RUN:-false}"

RSYNC=(rsync -aAXHv --info=progress2,stats --delete --numeric-ids --exclude='lost+found/' --exclude='.git/index' --exclude='.git/*/index')

if [[ "$DRY_RUN" == "true" ]]; then
  echo "=== DRY RUN MODE (no changes will be made) ==="
  RSYNC+=(--dry-run)
fi

LOG_FILE="/tmp/backup_${DATE}.log"

exec > >(tee -a "$LOG_FILE") 2>&1
echo "=== Backup started at $DATE ==="

# -------------------
# SAFETY CHECKS
# -------------------
for d in "$BKP_01" "$ARCHIVE"; do
  mountpoint -q "$d" || { echo "ERROR: $d not mounted"; exit 1; }
done

# prevent concurrent runs
exec 9>/tmp/backup.lock
flock -n 9 || { echo "Another backup is running"; exit 1; }

# -------------------
# BACKUP TO BASE
# -------------------

ssh -o BatchMode=yes -o ConnectTimeout=5 "$BATOCERA_REMOTE" "true" >/dev/null 2>&1 \
  || { echo "ERROR: cannot reach Batocera host ($BATOCERA_IP)"; exit 1; }
echo "# Backup"
echo "## Batocera backup"
"${RSYNC[@]}" \
  --backup \
  --backup-dir="$BKP_01/.backup/$DATE/live/batocera/userdata" \
  "$BATOCERA_REMOTE:/userdata/" \
  "$BKP_01/live/batocera/userdata/"

echo "## Docs backup"
"${RSYNC[@]}" \
  --backup \
  --backup-dir="$BKP_01/.backup/$DATE/live/docs" \
  "$HOME/docs/" \
  "$BKP_01/live/docs/"

echo "## Archive backup"
"${RSYNC[@]}" \
  --backup \
  --backup-dir="$BKP_01/.backup/$DATE/archive" \
  "$ARCHIVE/" \
  "$BKP_01/archive/"

echo "Backup completed successfully: $DATE"

echo
echo "# Check for old rsync backups"
find "$BKP_01/.backup" \
  -mindepth 1 -maxdepth 1 \
  -type d \
  -name "20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]*" \
  -mtime +100 -print \
| sed 's/^/Consider deleting (older than 100 days): /'

# current SMART
echo
echo "# Check disks health"
echo "## Local disks health"
sudo env "PATH=$PATH" check_disks_health
echo "## Batocera disks health"
ssh root@$BATOCERA_IP 'bash -s' < check_disks_health
