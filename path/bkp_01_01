#!/usr/bin/env bash

set -ueo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "$SCRIPT_DIR/lib/backup_lib.sh"

MAX_SNAPHOT_AGE=100
DRY_RUN="${DRY_RUN:-false}"

DATE="$(date +%F_%H-%M-%S)"

if [[ $EUID -ne 0 ]]; then
    echo "Run with sudo..."
    exit 1
fi

##################
# Enable logging #
##################
setup_logging "bkp_01_01" "$DATE"

################
# Mount points #
################
BKP_01_01="/mnt/bkp_01_01"
ARCHIVE="/run/media/fede/archive"

###########
# Remotes #
###########
BATOCERA_REMOTE="root@BATOCERA.local"

#############
# Rsync cmd #
#############
setup_rsync

################
# Safety check #
################
check_mounts "$BKP_01_01" "$BKP_01_01/.snapshots" "$ARCHIVE"

setup_lock

ssh -o BatchMode=yes -o ConnectTimeout=5 "$BATOCERA_REMOTE" "true" >/dev/null 2>&1 \
    || { echo "ERROR: cannot reach $BATOCERA_REMOTE"; exit 1; }

##############
# Rsync pull #
##############
mkdir -p $BKP_01_01/batocera
echo "## Batocera backup"
"${RSYNC[@]}" "$BATOCERA_REMOTE:/userdata/" "$BKP_01_01/batocera/userdata/"

echo "## Docs backup"
"${RSYNC[@]}" "/home/fede/docs/" "$BKP_01_01/docs/"

echo "## Archive backup"
"${RSYNC[@]}" "$ARCHIVE/" "$BKP_01_01/archive/"

############
# SNAPSHOT #
############
echo "# Creating snapshot"
SNAPSHOT_DIR="$BKP_01_01/.snapshots/$DATE"
if [[ "$DRY_RUN" != "true" ]]; then
    btrfs subvolume snapshot -r "$BKP_01_01" "$SNAPSHOT_DIR"
    echo "Snapshot created: $SNAPSHOT_DIR"
fi

#######################
# PRUNE OLD SNAPSHOTS #
#######################
echo "# Checking snapshots older than $MAX_SNAPHOT_AGE days"
find "$BKP_01_01/.snapshots" \
    -mindepth 1 -maxdepth 1 \
    -type d \
    -mtime +$MAX_SNAPHOT_AGE \
    -exec echo "Consider deleting old snapshot {} by running: btrfs subvolume delete \"{}\"" \;

################
# Scrub        #
################
echo "# Scrubing"
echo "## Scrubbing backup disk"
btrfs scrub start -B "$BKP_01_01"
echo "## Scrubbing system disk"
btrfs scrub start -B /

################
# Disk health  #
################
echo "# Checking disk health"
echo "## Local disks"
$SCRIPT_DIR/check_disks_health || true
echo "## Batocera disks"
ssh "$BATOCERA_REMOTE" 'bash -s' < "$SCRIPT_DIR/check_disks_health" || true

echo "Backup and checks completed: $DATE"
