#!/usr/bin/env bash

set -ueo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "$SCRIPT_DIR/lib/backup_lib.sh"

MAX_SNAPSHOT_AGE=100
DRY_RUN="${DRY_RUN:-false}"

DATE="$(date +%F_%H-%M-%S)"

if [[ $EUID -ne 0 ]]; then
    echo "Run with sudo..."
    exit 1
fi

##################
# Enable logging #
##################
setup_logging "bkp_01_01" "$DATE"

################
# Mount points #
################
BKP_01_01="/mnt/bkp_01_01"
BKP_01_01_DATA="$BKP_01_01/@"
BKP_01_01_SNAPSHOTS="$BKP_01_01/@.snapshots"
ARCHIVE="/run/media/fede/archive"

###########
# Remotes #
###########
BATOCERA_REMOTE="root@BATOCERA.local"

#############
# Rsync cmd #
#############
setup_rsync

################
# Safety check #
################
check_mounts "$BKP_01_01" "$ARCHIVE"

setup_lock

ssh -o BatchMode=yes -o ConnectTimeout=5 "$BATOCERA_REMOTE" "true" >/dev/null 2>&1 \
    || { echo "ERROR: cannot reach $BATOCERA_REMOTE"; exit 1; }

##############
# Rsync pull #
##############
mkdir -p "$BKP_01_01_DATA/batocera"
echo "## Batocera backup"
"${RSYNC[@]}" "$BATOCERA_REMOTE:/userdata/" "$BKP_01_01_DATA/batocera/userdata/"

echo "## Docs backup"
"${RSYNC[@]}" "/home/fede/docs/" "$BKP_01_01_DATA/docs/"

echo "## Archive backup"
"${RSYNC[@]}" "$ARCHIVE/" "$BKP_01_01_DATA/archive/"

############
# SNAPSHOT #
############
echo "# Creating snapshot"
create_snapshot \
    "$BKP_01_01_DATA" \
    "$BKP_01_01_SNAPSHOTS" \
    "$DATE"

#######################
# PRUNE OLD SNAPSHOTS #
#######################
echo "# Checking snapshots older than $MAX_SNAPSHOT_AGE days"
check_snapshot_age \
    "$BKP_01_01_SNAPSHOTS" \
    "$MAX_SNAPSHOT_AGE"

################
# Scrub        #
################
echo "# Scrubing"
echo "## Scrubbing backup disk"
btrfs scrub start -B "$BKP_01_01"
echo "## Scrubbing archive disk"
btrfs scrub start -B "$ARCHIVE"
echo "## Scrubbing system disk"
btrfs scrub start -B /

################
# Disk health  #
################
echo "# Checking disk health"
echo "## Local disks"
$SCRIPT_DIR/check_disks_health || true
echo "## Batocera disks"
ssh "$BATOCERA_REMOTE" 'bash -s' < "$SCRIPT_DIR/check_disks_health" || true

echo "Backup and checks completed: $DATE"
