#!/usr/bin/env bash

set -uo pipefail

source "$(dirname "$(readlink -f "$0")")/lib/backup_lib.sh"

DATE="$(date +%F_%H-%M-%S)"

DRY_RUN="${DRY_RUN:-false}"

if [[ $EUID -ne 0 ]]; then
    echo "Run with sudo..."
    exit 1
fi

##################
# Enable logging #
##################
setup_logging "bkp_01_02" "$DATE"

################
# Mount points #
################
BKP_01_01="/mnt/bkp_01_01"
BKP_01_01_DATA="$BKP_01_01/@"
BKP_01_02="/run/media/fede/bkp_01_02"
BKP_01_02_DATA="$BKP_01_02/@"
BKP_01_02_SNAPSHOT="$BKP_01_02/@.snapshots/"

#############
# Rsync cmd #
#############
setup_rsync

################
# Safety check #
################
check_mounts "$BKP_01_01" "$BKP_01_02"

setup_lock

##########
# Mirror #
##########
echo "# Mirroring bkp_01_01 to bkp_01_02"
"${RSYNC[@]}" "$BKP_01_01_DATA/" "$BKP_01_02_DATA/"

############
# SNAPSHOT #
############
echo "# Creating snapshot"
SNAPSHOT_DIR="$BKP_01_02_SNAPSHOT/$DATE"
if [[ "$DRY_RUN" != "true" ]]; then
    btrfs subvolume snapshot -r "$BKP_01_02_DATA/@" "$SNAPSHOT_DIR"
    echo "Snapshot created: $SNAPSHOT_DIR"
fi

##########
# Scrub  #
##########
echo "# Scrubbing mirror disk"
btrfs scrub start -B "$BKP_01_02_DATA"

################
# Disk health  #
################
echo "# Checking disk health"
check_disks_health || true

echo "Mirror completed: $DATE"
